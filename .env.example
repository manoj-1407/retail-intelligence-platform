# Copy to .env and fill in all values before running docker-compose

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_db
DB_USER=postgres
DB_PASS=change_me_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Security
JWT_SECRET=replace_with_a_64_char_random_string_generated_by_openssl_rand
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Built-in user passwords
ADMIN_PASSWORD=change_me_admin
VIEWER_PASSWORD=change_me_viewer

# CORS
CORS_ORIGINS=http://localhost:5173

# Kafka (optional)
KAFKA_BOOTSTRAP=localhost:9092

# Logging
LOG_LEVEL=INFO
